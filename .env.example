# Discord Bot Configuration
# Copy this file to .env and fill in your actual values

# Main Bot Configuration
MAIN_BOT_TOKEN=your_main_discord_bot_token_here
MAIN_GUILD_ID=your_main_guild_id_here
MAIN_REPORT_CHANNEL_ID=your_main_report_channel_id_here
MAIN_TRACKED_VOICE_CHANNEL_ID=your_main_tracked_voice_channel_id_here

# Test Bot Configuration (optional)
TEST_BOT_TOKEN=your_test_discord_bot_token_here
TEST_GUILD_ID=your_test_guild_id_here
TEST_REPORT_CHANNEL_ID=your_test_report_channel_id_here
TEST_TRACKED_VOICE_CHANNEL_ID=your_test_tracked_voice_channel_id_here
